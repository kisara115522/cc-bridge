{
  "name": "cc-bridge",
  "version": "0.1.0",
  "description": "Telegram bridge for remotely operating local Codex and Claude Code CLI sessions.",
  "type": "module",
  "bin": {
    "cc-bridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts start",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "node-pty": "^1.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/node-telegram-bot-api": "^0.64.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
